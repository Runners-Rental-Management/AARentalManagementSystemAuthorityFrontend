# Copy to .env and adjust
VITE_API_BASE_URL=http://localhost:3000

# If npm install fails with UNABLE_TO_VERIFY_LEAF_SIGNATURE, run: .\install.ps1
# Or set registry in .npmrc (see authority-portal/.npmrc)

# Or proxy via Vite dev server (avoids CORS)
# VITE_API_USE_PROXY=1
# BACKEND_PROXY_TARGET=http://127.0.0.1:3000
